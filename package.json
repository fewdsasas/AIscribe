{
  "name": "aiscribe",
  "version": "0.1.0",
  "description": "AIscribe - AI Novel Creation Platform",
  "author": "AIscribe Team",
  "license": "MIT",
  "repository": "github:aiscribe/aiscribe",
  "bugs": "https://github.com/aiscribe/aiscribe/issues",
  "homepage": "https://github.com/aiscribe/aiscribe",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-builder",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --exclude tests/integration/stress-*.test.ts --exclude tests/integration/memory-*.test.ts",
    "test:stress": "vitest run tests/integration/stress-db.test.ts tests/integration/stress-llm.test.ts tests/integration/stress-ipc.test.ts",
    "test:integration": "vitest run tests/integration/ --exclude tests/integration/stress-*.test.ts",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:build": "npm run build && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --report-unused-disable-directives --max-warnings=0",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.11.0",
    "uuid": "^11.1.0",
    "yaml": "^2.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@playwright/test": "^1.61.1",
    "@swc/core": "^1.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-underline": "^2.11.5",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "electron": "^42.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  }
}
