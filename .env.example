# AIscribe Environment Configuration
# Copy this file to .env and fill in your API keys

# LLM API Keys
OPENAI_API_KEY=sk-your-openai-api-key
CLAUDE_API_KEY=sk-ant-your-claude-api-key
MIMO_API_KEY=your-mimo-api-key
WENXIN_API_KEY=your-wenxin-api-key
TONGYI_API_KEY=your-tongyi-api-key

# Custom provider (compatible with OpenAI API format)
CUSTOM_API_KEY=your-custom-api-key
CUSTOM_BASE_URL=https://your-custom-endpoint.com/v1
CUSTOM_DEFAULT_MODEL=custom-model-name

# Custom base URL for OpenAI-compatible providers
OPENAI_BASE_URL=

# Default LLM Provider (openai | claude | mimo | wenxin | tongyi | custom)
DEFAULT_LLM_PROVIDER=openai

# Default Model
OPENAI_DEFAULT_MODEL=gpt-4o
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-20250514
MIMO_DEFAULT_MODEL=mimo-pro
WENXIN_DEFAULT_MODEL=ernie-4.0
TONGYI_DEFAULT_MODEL=qwen-max
